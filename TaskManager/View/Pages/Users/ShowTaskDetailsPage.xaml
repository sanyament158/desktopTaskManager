<Page x:Class="TaskManager.View.Pages.Users.ShowTaskDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ShowTaskDetailsPage" Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Grid.Row="0"
                   Style="{StaticResource HeaderTextBlock}"
                   Foreground="Black"
                   HorizontalAlignment="Center">
            <Run Text="Детали задачи "/>
            <Run Text="{Binding EnteredTask.Title}"/>
        </TextBlock>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="50 20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- labels -->
            <TextBlock Text="Владелец:" Grid.Row="0" Grid.Column="0"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Right" Margin="10"/>

            <TextBlock Text="Область:" Grid.Row="1" Grid.Column="0"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Right" Margin="10"/>

            <TextBlock Text="Начало:" Grid.Row="2" Grid.Column="0"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Right" Margin="10"/>

            <TextBlock Text="Дедлайн:" Grid.Row="3" Grid.Column="0"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Right" Margin="10"/>

            <TextBlock Text="Статус:" Grid.Row="4" Grid.Column="0"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Right" Margin="10"/>

            <TextBlock Text="Задачу взял:" Grid.Row="5" Grid.Column="0"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Right" Margin="10"
                       Visibility="{Binding IsTaked}"/>

            <!-- values -->
            <TextBlock Text="{Binding EnteredTask.Owner.Lname}"
                       Grid.Row="0" Grid.Column="1"
                       Style="{StaticResource FieldTextBlock}"
                       Margin="10"/>

            <TextBlock Text="{Binding EnteredTask.Scope.Name}"
                       Grid.Row="1" Grid.Column="1"
                       Style="{StaticResource FieldTextBlock}"
                       Margin="10"/>

            <TextBlock Text="{Binding EnteredTask.Since, StringFormat=\{0:d\}}"
                       Grid.Row="2" Grid.Column="1"
                       Style="{StaticResource FieldTextBlock}"
                       Margin="10"/>

            <TextBlock Text="{Binding EnteredTask.Deadline, StringFormat=\{0:d\}}"
                       Grid.Row="3" Grid.Column="1"
                       Style="{StaticResource FieldTextBlock}"
                       Margin="10"/>

            <TextBlock Text="{Binding EnteredTask.Status.Name}"
                       Grid.Row="4" Grid.Column="1"
                       Style="{StaticResource FieldTextBlock}"
                       Margin="10"/>

            <TextBlock Text="{Binding UserTakedText}"
                       Grid.Row="5" Grid.Column="1"
                       Style="{StaticResource FieldTextBlock}"
                       Margin="10"
                       Visibility="{Binding IsTaked}"/>

            <!-- TAKE TO USER BLOCK -->
            <Grid Grid.Row="5" Grid.Column="1"
                  Visibility="{Binding TakeToUserVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Margin="10"
                          Style="{StaticResource BaseComboBox}"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          DisplayMemberPath="Lname"/>

                <Border Grid.Column="1"
                        Margin="10"
                        Style="{StaticResource ButtonStackPanel}">
                    <Button Content="Назначить"
                            Command="{Binding TakeToUserCommand}"
                            Style="{StaticResource BaseButton}"/>
                </Border>
            </Grid>

        </Grid>

        <!-- BACK / ACTIONS -->
        <Grid Grid.Row="2" Margin="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Border Style="{StaticResource ButtonStackPanel}" Margin="10">
                    <Button Content="{StaticResource back}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding GoBackCommand}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10"
                        Visibility="{Binding MarkAsFinishVisibility}">
                    <Button Content="{StaticResource finished}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding MarkAsFinishCommand}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10"
                        Visibility="{Binding IsCheckedVisibility}">
                    <Button Content="{StaticResource checked}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding CheckTaskCommand}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10"
                        Visibility="{Binding IsWaitingVisibility}">
                    <Button Content="{StaticResource takeTask}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding TakeTaskCommand}"/>
                </Border>

            </StackPanel>
        </Grid>

    </Grid>
</Page>
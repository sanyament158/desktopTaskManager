<Page x:Class="TaskManager.View.Pages.Users.TakedTasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Users"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d"
      Background="White"
      Title="TakedTasksPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Style="{StaticResource HeaderStackPanel}"
                >

            <TextBlock Text="Взятые задачи"
                       Style="{StaticResource HeaderTextBlock}"
                       HorizontalAlignment="Center" Margin="0 20"/>
        </Border>

        <!-- ACTION BAR -->
        <Grid Grid.Row="1" Margin="10">

            <Border Width="160"
                    HorizontalAlignment="Right"
                    Style="{StaticResource ButtonStackPanel}">

                <Button Content="Отчет в Excel"
                        Style="{StaticResource BaseButton}"
                        Command="{Binding ReportCommand}"/>
            </Border>

        </Grid>

        <!-- LIST -->
        <Border Grid.Row="2"
                Margin="10"
                Background="Transparent">

            <ListView ItemsSource="{Binding Tasks}"
                      SelectedItem="{Binding SelectedTask}"
                      BorderThickness="0"
                      Background="Transparent"
                      FontSize="16">

                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding GoToShowDetailsCommand}"
                                               CommandParameter="{Binding SelectedTask}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="Владелец"
                                        DisplayMemberBinding="{Binding Owner.Lname}"
                                        Width="140"/>

                        <GridViewColumn Header="Статус"
                                        DisplayMemberBinding="{Binding Status.Name}"
                                        Width="120"/>

                        <GridViewColumn Header="Заголовок"
                                        DisplayMemberBinding="{Binding Title}"
                                        Width="200"/>

                        <GridViewColumn Header="Начало"
                                        DisplayMemberBinding="{Binding Since, StringFormat=\{0:d\}}"
                                        Width="120"/>

                        <GridViewColumn Header="Дедлайн"
                                        DisplayMemberBinding="{Binding Deadline, StringFormat=\{0:d\}}"
                                        Width="120"/>

                        <GridViewColumn Header="Зона"
                                        DisplayMemberBinding="{Binding Scope.Name}"
                                        Width="160"/>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- BACK -->
        <Border Grid.Row="3"
                Style="{StaticResource ButtonStackPanel}"
                Margin="250 10">

            <Button Content="{StaticResource back}"
                    Style="{StaticResource BigButton}"
                    Command="{Binding GoBackCommand}"/>
        </Border>

    </Grid>
</Page>
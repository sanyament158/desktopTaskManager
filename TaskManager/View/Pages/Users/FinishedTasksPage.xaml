<Page x:Class="TaskManager.View.Pages.Users.FinishedTasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Users"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d"
      Background="White"
      Title="FinishedTasksPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FILTER PANEL -->
        <Border Background="{StaticResource grey}"
        CornerRadius="10"
        Padding="10"
        Margin="5">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.6*"/>
                </Grid.ColumnDefinitions>

                <!-- LABELS -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Заголовок"
                   Style="{StaticResource InfoTextBlock}"
                   HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="1"
                   Text="Начало"
                   Style="{StaticResource InfoTextBlock}"
                   HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2"
                   Text="Дедлайн"
                   Style="{StaticResource InfoTextBlock}"
                   HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="3"
                   Text="Область"
                   Style="{StaticResource InfoTextBlock}"
                   HorizontalAlignment="Center"/>

                <!-- CONTROLS (BELOW LABELS) -->
                <TextBox Grid.Row="1" Grid.Column="0"
                 Style="{StaticResource BaseTextBox}"
                 Background="White"
                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                 Margin="5"/>

                <DatePicker Grid.Row="1" Grid.Column="1"
                FontSize="16"
                    SelectedDate="{Binding Since}"
                    Margin="5"
                    BorderThickness="0"/>

                <DatePicker Grid.Row="1" Grid.Column="2"
                FontSize="16"
                    SelectedDate="{Binding Deadline}"
                    Margin="5"
                    BorderThickness="0"/>

                <ComboBox Grid.Row="1" Grid.Column="3"
                  Style="{StaticResource BaseComboBox}"
                  ItemsSource="{Binding Scopes}"
                  SelectedItem="{Binding SelectedScope}"
                  DisplayMemberPath="Name"
                  Margin="5"/>

            </Grid>
        </Border>
        <!-- LIST -->
        <Border Grid.Row="1"
                Margin="5"
                Background="Transparent">

            <ListView ItemsSource="{Binding Tasks}"
                      SelectedItem="{Binding SelectedTask}"
                      BorderThickness="0"
                      Background="Transparent"
                      FontSize="16">

                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding GoToShowDetailsCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="Владелец"
                                        DisplayMemberBinding="{Binding Owner.Lname}"
                                        Width="140"/>

                        <GridViewColumn Header="Статус"
                                        DisplayMemberBinding="{Binding Status.Name}"
                                        Width="120"/>

                        <GridViewColumn Header="Заголовок"
                                        DisplayMemberBinding="{Binding Title}"
                                        Width="200"/>

                        <GridViewColumn Header="Начало"
                                        DisplayMemberBinding="{Binding Since}"
                                        Width="120"/>

                        <GridViewColumn Header="Дедлайн"
                                        DisplayMemberBinding="{Binding Deadline}"
                                        Width="120"/>

                        <GridViewColumn Header="Зона"
                                        DisplayMemberBinding="{Binding Scope.Name}"
                                        Width="160"/>

                        <GridViewColumn Header="Выполнил"
                                        DisplayMemberBinding="{Binding CompletedBy}"
                                        Width="160"/>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</Page>
<Page x:Class="TaskManager.ViewModel.Pages.SignUpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.ViewModel.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignUpPage" Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Style="{StaticResource HeaderStackPanel}"
                CornerRadius="0 0 15 15">
            <TextBlock Text="Регистрация нового пользователя"
                       Style="{StaticResource HeaderTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 20"/>
        </Border>

        <!-- FORM -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

            <Border Style="{StaticResource BaseStackPanel}"
                    Background="{StaticResource grey}"
                    Margin="20">

                <Grid Margin="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- labels -->
                    <TextBlock Text="Логин:"
                               Grid.Row="0" Grid.Column="0"
                               Style="{StaticResource InfoTextBlock}"
                               HorizontalAlignment="Right"
                               Margin="10"/>

                    <TextBlock Text="Пароль:"
                               Grid.Row="1" Grid.Column="0"
                               Style="{StaticResource InfoTextBlock}"
                               HorizontalAlignment="Right"
                               Margin="10"/>

                    <TextBlock Text="Фамилия:"
                               Grid.Row="2" Grid.Column="0"
                               Style="{StaticResource InfoTextBlock}"
                               HorizontalAlignment="Right"
                               Margin="10"/>

                    <!-- inputs -->
                    <Border Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource BaseStackPanel}"
                            Margin="10">
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BaseTextBox}"/>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource BaseStackPanel}"
                            Margin="10">
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BaseTextBox}"/>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="1"
                            Style="{StaticResource BaseStackPanel}"
                            Margin="10">
                        <TextBox Text="{Binding Lname, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BaseTextBox}"/>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <!-- BUTTONS -->
        <Grid Grid.Row="2" Margin="20">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10"
                        Width="120">
                    <Button Content="Назад"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding GoBackCommand}"
                            CommandParameter="{Binding ElementName=buttonBack}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10"
                        Width="120">
                    <Button Content="{StaticResource accept}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding AcceptCommand}"
                            CommandParameter="{Binding ElementName=buttonAccept}"/>
                </Border>

            </StackPanel>
        </Grid>

    </Grid>
</Page>
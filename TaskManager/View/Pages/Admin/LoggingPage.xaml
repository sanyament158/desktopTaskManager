<Page x:Class="TaskManager.View.Pages.Admin.LoggingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoggingPage">

    <Grid Margin="30">
        <ListView x:Name="LoggingListView" Margin="10" ItemsSource="{Binding Logs}" 
                          BorderThickness="0" FontSize="16">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Пользователь" Width="150" DisplayMemberBinding="{Binding User.Lname}" />
                    <GridViewColumn Header="Действие" Width="300" DisplayMemberBinding="{Binding Action}" />
                    <GridViewColumn Header="Время" Width="150" DisplayMemberBinding="{Binding Time}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>

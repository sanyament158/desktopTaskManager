<Page x:Class="TaskManager.View.Pages.Admin.ViewResponsibilities"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ViewResponsibilities"
      Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeaderStackPanel}" Grid.ColumnSpan="2" 
                Padding="20" Margin="10" VerticalAlignment="Top">
            <TextBlock Text="Оценка загруженности сотрудников" 
                       Style="{StaticResource HeaderTextBlock}"/>
        </Border>

        <TextBlock x:Name="textBlockRatio" Grid.Row="1" Grid.ColumnSpan="2"
                   Text="{Binding Ratio}"
                   Style="{StaticResource InfoTextBlock}"
                   />

        <ListView x:Name="listViewEmployees" Grid.Row="2" Margin="10"
                  ItemsSource="{Binding Users}" BorderThickness="0"
            >
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Фамилия" DisplayMemberBinding="{Binding Lname}"/>
                </GridView>
            </ListView.View>
        </ListView>
        
        <ListView x:Name="listViewScopes" Grid.Row="2" Grid.Column="1" Margin="10"
          ItemsSource="{Binding Scopes}" BorderThickness="0"
          SelectedItem="{Binding SelectedCategory}"
            >
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding Name}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Border x:Name="borderBack" Grid.Row="3" Grid.ColumnSpan="2"
                Style="{StaticResource ButtonStackPanel}"
                Margin="190 16 190 16">
            <Button x:Name="buttonBack" 
                    Command="{Binding GoBackCommand}"
                    Content="{StaticResource back}"
                    Style="{StaticResource BigButton}"
                    />
        </Border>
    </Grid>
</Page>

<Page x:Class="TaskManager.View.Pages.Admin.EditEmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d"
      Title="EditEmployeesPage"
      Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0"
                Background="#F5F5F5"
                CornerRadius="10"
                Padding="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Доступные действия"
                           Style="{StaticResource InfoTextBlock}"
                           Margin="5"
                           HorizontalAlignment="Center"/>

                <StackPanel Grid.Row="1" Margin="0 10 0 0">

                    <Border Style="{StaticResource ButtonStackPanel}" Margin="5">
                        <Button Content="Добавить сотрудника"
                                Style="{StaticResource BigButton}"
                                Command="{Binding GoToAddEmployeeCommand}"/>
                    </Border>

                    <Border Style="{StaticResource ButtonStackPanel}" Margin="5">
                        <Button Content="Удалить сотрудника"
                                Style="{StaticResource BigButton}"
                                Command="{Binding DeleteUserCommand}"/>
                    </Border>

                    <Border Style="{StaticResource ButtonStackPanel}" Margin="5">
                        <Button Content="Редактировать"
                                Style="{StaticResource BigButton}"
                                Command="{Binding GoToUpdateUserCommand}"/>
                    </Border>

                    <Border Style="{StaticResource ButtonStackPanel}" Margin="5">
                        <Button Content="Загруженность"
                                Style="{StaticResource BigButton}"
                                Command="{Binding GoToViewScopeCommand}"/>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="1"
                Margin="20 0 0 0"
                Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Все пользователи"
                           Style="{StaticResource InfoTextBlock}"
                           Margin="10"/>

                <ListView x:Name="listViewUsers"
                          Grid.Row="1"
                          Margin="10"
                          FontSize="16"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          BorderThickness="0">

                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Фамилия"
                                            DisplayMemberBinding="{Binding Lname}"
                                            Width="180"/>
                            <GridViewColumn Header="Роль"
                                            DisplayMemberBinding="{Binding Role.Name}"
                                            Width="140"/>
                            <GridViewColumn Header="Зоны"
                                            DisplayMemberBinding="{Binding Scopes.Count}"
                                            Width="140"/>
                        </GridView>
                    </ListView.View>

                </ListView>

            </Grid>
        </Border>

        <!-- BACK BUTTON -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0 15 0 0"
                HorizontalAlignment="Left"
                Style="{StaticResource ButtonStackPanel}">

            <Button Content="{StaticResource back}"
                    Style="{StaticResource BaseButton}"
                    Command="{Binding GoBackCommand}"/>
        </Border>

    </Grid>
</Page>
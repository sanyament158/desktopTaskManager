<Page x:Class="TaskManager.View.Pages.Admin.AddTaskPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d"
      Title="AddTaskPage"
      Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Добавить задачу"
                   Style="{StaticResource FieldTextBlock}"
                   HorizontalAlignment="Center"
                   Margin="0 20"/>

        <!-- FORM -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="520"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1"
                    Background="{StaticResource grey}"
                    CornerRadius="10"
                    Margin="10"
                    Padding="20">

                <StackPanel HorizontalAlignment="Center"
                            Width="400">

                    <!-- OWNER -->
                    <StackPanel Margin="0 8">
                        <TextBlock Text="Владелец"
                                   Style="{StaticResource InfoTextBlock}"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 5"/>
                        <Border Style="{StaticResource BaseStackPanel}">
                            <TextBox Text="{Binding Owner, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource BaseTextBox}"/>
                        </Border>
                    </StackPanel>

                    <!-- SCOPE -->
                    <StackPanel Margin="0 8">
                        <TextBlock Text="Область"
                                   Style="{StaticResource InfoTextBlock}"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 5"/>
                        <ComboBox ItemsSource="{Binding Scopes}"
                                  SelectedValue="{Binding IdScope}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Style="{StaticResource BaseComboBox}"/>
                    </StackPanel>

                    <!-- TITLE -->
                    <StackPanel Margin="0 8">
                        <TextBlock Text="Заголовок"
                                   Style="{StaticResource InfoTextBlock}"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 5"/>
                        <Border Style="{StaticResource BaseStackPanel}">
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource BaseTextBox}"/>
                        </Border>
                    </StackPanel>

                    <!-- SINCE -->
                    <StackPanel Margin="0 8">
                        <TextBlock Text="Начало"
                                   Style="{StaticResource InfoTextBlock}"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 5"/>
                        <Border Style="{StaticResource BaseStackPanel}">
                            <TextBox Text="{Binding Since, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource BaseTextBox}"/>
                        </Border>
                    </StackPanel>

                    <!-- DEADLINE -->
                    <StackPanel Margin="0 8">
                        <TextBlock Text="Дедлайн"
                                   Style="{StaticResource InfoTextBlock}"
                                   HorizontalAlignment="Center"
                                   Margin="0 0 0 5"/>
                        <Border Style="{StaticResource BaseStackPanel}">
                            <TextBox Text="{Binding Deadline, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource BaseTextBox}"/>
                        </Border>
                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>

        <!-- BUTTONS -->
        <Grid Grid.Row="2" Margin="0 20">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button Content="{StaticResource add}"
                            Name="buttonAccept"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding AcceptCommand}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button Content="{StaticResource back}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding GoBackCommand}"/>
                </Border>

            </StackPanel>

        </Grid>

    </Grid>
</Page>
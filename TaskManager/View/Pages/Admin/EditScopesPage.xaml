<Page x:Class="TaskManager.View.Pages.Admin.EditScopesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d"
      Title="EditScopesPage"
      Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LEFT PANEL (ACTIONS) -->
        <Border Grid.Column="0"
                Grid.Row="0"
                Background="#F5F5F5"
                CornerRadius="10"
                Padding="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Доступные действия"
                           Style="{StaticResource InfoTextBlock}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="5"/>

                <StackPanel Grid.Row="1" Margin="0 10 0 0">

                    <Border Style="{StaticResource ButtonStackPanel}" Margin="5">
                        <Button Content="Добавить"
                                Style="{StaticResource BigButton}"
                                Command="{Binding GoToAddScopeCommand}"/>
                    </Border>

                    <Border Style="{StaticResource ButtonStackPanel}" Margin="5">
                        <Button Content="Удалить"
                                Style="{StaticResource BigButton}"
                                Command="{Binding DeleteScopeCommand}"/>
                    </Border>

                    <Border Style="{StaticResource ButtonStackPanel}" Margin="5">
                        <Button Content="Изменить"
                                Style="{StaticResource BigButton}"
                                Command="{Binding GoToUpdateScopeCommand}"/>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT PANEL (LIST) -->
        <Border Grid.Column="1"
                Grid.Row="0"
                Margin="20 0 0 0"
                Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Все зоны ответственности"
                           Style="{StaticResource InfoTextBlock}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="10"/>

                <ListView x:Name="listViewScopes"
                          Grid.Row="1"
                          ItemsSource="{Binding Scopes}"
                          SelectedItem="{Binding SelectedScope}"
                          BorderThickness="0"
                          Margin="10"
                          FontSize="16">

                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Имя"
                                            DisplayMemberBinding="{Binding Name}"
                                            Width="300"/>
                        </GridView>
                    </ListView.View>

                </ListView>
            </Grid>
        </Border>

        <!-- BACK BUTTON -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0 15 0 0"
                HorizontalAlignment="Left"
                Style="{StaticResource ButtonStackPanel}">

            <Button Content="{StaticResource back}"
                    Style="{StaticResource BaseButton}"
                    Padding="25 10"
                    Command="{Binding GoBackCommand}"/>
        </Border>

    </Grid>
</Page>
<Page x:Class="TaskManager.View.Pages.Admin.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReportsPage" Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid>
            <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="0 50 0 0">
                <Border x:Name="borderExcelReport" Height="50"
                        Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button x:Name="buttonExcelReport" Content="Экспорт в Excel" 
                            Style="{StaticResource BigButton}"
                            Command="{Binding ExcelReportCommand}"/>
                </Border>
                <Border x:Name="borderWordReport" Height="50"
                        Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button x:Name="buttonWordReport" Content="Экспорт в Word"
                            Style="{StaticResource BigButton}"
                            Command="{Binding WordReportCommand}"/>
                </Border>
            </StackPanel>
            <Border x:Name="borderBack" Height="50" VerticalAlignment="Bottom"
                    Style="{StaticResource ButtonStackPanel}"
                    Margin="10">
                <Button x:Name="buttonBack" 
                        Content="{StaticResource back}"
                        Style="{StaticResource BigButton}"
                        Command="{Binding GoBackCommand}"/>
            </Border>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1.8*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Grid.ColumnSpan="2">
                <TextBlock Text="Статус" Margin="10"
                   Style="{StaticResource FieldTextBlock}"/>
                <ComboBox x:Name="comboboxStatus" VerticalAlignment="Bottom"
                         Height="40" Margin="80 0 80 0"
                         Style="{StaticResource BaseComboBox}"
                         ItemsSource="{Binding Statuses}"
                         SelectedItem="{Binding SelectedStatus}"
                         DisplayMemberPath="Name"
                         SelectedValuePath="Id"
                         />
            </StackPanel>
            <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Grid.ColumnSpan="2" Grid.Row="1">
                <TextBlock Text="Зона ответственности" Margin="10"
                   Style="{StaticResource FieldTextBlock}"/>
                <ComboBox x:Name="comboboxScopes" VerticalAlignment="Bottom"
                         Height="40" Margin="80 0 80 0"
                         Style="{StaticResource BaseComboBox}"
                         ItemsSource="{Binding Scopes}"
                         SelectedItem="{Binding SelectedScope}"
                         DisplayMemberPath="Name"
                         SelectedValuePath="Id"
                         />
            </StackPanel>
            <DatePicker x:Name="dateSince" Grid.Row="2" Margin="15"
                        BorderThickness="0" SelectedDate="{Binding Since}"/>
            <DatePicker x:Name="dateDeadline" Grid.Row="2" Grid.Column="1" Margin="15"
                        BorderThickness="0" SelectedDate="{Binding Deadline}"/>
        </Grid>
    </Grid>
</Page>

<Page x:Class="TaskManager.View.Pages.Admin.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      xmlns:controls="clr-namespace:TaskManager.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReportsPage" Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid>
            <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="0 50 0 0">
                <Border x:Name="borderControlSwitcher" Height="50"
                        Style="{StaticResource ButtonStackPanel}"
                        Background="{StaticResource lightBrown}"
                        Margin="10">
                    <Button x:Name="buttonControlSwitcher" Content="{Binding SwitcherButtonContent}" 
                            Style="{StaticResource BigButton}"
                            Command="{Binding ControlSwitcherCommand}"/>
                </Border>
                <Border x:Name="borderExcelReport" Height="50"
                        Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button x:Name="buttonExcelReport" Content="Экспорт в Excel" 
                            Style="{StaticResource BigButton}"
                            Command="{Binding ExcelReportCommand}"/>
                </Border>
                <Border x:Name="borderWordReport" Height="50"
                        Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button x:Name="buttonWordReport" Content="Экспорт в Word"
                            Style="{StaticResource BigButton}"
                            Command="{Binding WordReportCommand}"/>
                </Border>
            </StackPanel>
        </Grid>
        <controls:TasksReportUserControl Grid.Column="1" Visibility="{Binding TasksControlVisibility}"/>
        <controls:UsersReportUserControl Grid.Column="1" Visibility="{Binding UsersControlVisibility}"/>
    </Grid>
</Page>

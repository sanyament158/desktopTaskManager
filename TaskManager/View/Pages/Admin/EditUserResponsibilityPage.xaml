<Page x:Class="TaskManager.View.Pages.Admin.EditUserResponsibilityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d"
      Title="EditUserResponsibilityPage"
      Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Style="{StaticResource HeaderStackPanel}">
            <TextBlock Text="Зоны ответственности сотрудника"
                       Grid.Row="0"
                       Style="{StaticResource HeaderTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 20"/>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- USER SCOPES -->
            <Border Grid.Column="0"
                    Background="{StaticResource grey}"
                    CornerRadius="10"
                    Margin="10"
                    Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource InfoTextBlock}">
                        <Run Text="{Binding SelectedUser.Lname}"/>
                        <Run Text=" ответственен за"/>
                    </TextBlock>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding UserScopes}"
                              SelectedItem="{Binding UserSelectedScope}"
                              Background="Transparent"
                              DisplayMemberPath="Name"
                              Margin="5"
                              BorderThickness="0"
                              FontSize="16"/>
                </Grid>
            </Border>

            <!-- MOVE BUTTONS -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="5">
                    <Button Content="→"
                            FontSize="30"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding MoveToAvailCommand}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="5">
                    <Button Content="←"
                            FontSize="30"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding MoveToUserCommand}"/>
                </Border>

            </StackPanel>

            <!-- AVAILABLE SCOPES -->
            <Border Grid.Column="2"
                    Background="{StaticResource grey}"
                    CornerRadius="10"
                    Margin="10"
                    Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Доступные зоны ответственности"
                               Style="{StaticResource InfoTextBlock}"/>

                    <ListView Grid.Row="1"
                              Background="Transparent"
                              ItemsSource="{Binding AvailScopes}"
                              SelectedItem="{Binding AvailSelectedScope}"
                              DisplayMemberPath="Name"
                              Margin="5"
                              BorderThickness="0"
                              FontSize="16"/>
                </Grid>
            </Border>

        </Grid>

        <!-- BACK -->
        <Border Grid.Row="2"
                HorizontalAlignment="Left"
                Style="{StaticResource ButtonStackPanel}"
                Margin="10 15">

            <Button Content="{StaticResource back}"
                    Style="{StaticResource BaseButton}"
                    Command="{Binding GoBackCommand}"/>
        </Border>

    </Grid>
</Page>
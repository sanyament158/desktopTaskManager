<Page x:Class="TaskManager.View.Pages.Admin.AddNewUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d"
      Title="AddNewUserPage"
      Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Style="{StaticResource HeaderStackPanel}">
            <TextBlock Text="Добавить нового пользователя"
                       Style="{StaticResource HeaderTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 20"/>
        </Border>

        <!-- FORM -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="480"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1"
        Background="{StaticResource grey}"
        CornerRadius="10"
        Margin="10"
        Padding="20">

                <StackPanel HorizontalAlignment="Center"
                Width="360">

                    <!-- LOGIN -->
                    <StackPanel Margin="0 10">
                        <TextBlock Text="Логин"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 5"/>

                        <Border Style="{StaticResource BaseStackPanel}">
                            <TextBox Text="{Binding InputedLogin, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource BaseTextBox}"/>
                        </Border>
                    </StackPanel>

                    <!-- SURNAME -->
                    <StackPanel Margin="0 10">
                        <TextBlock Text="Фамилия"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 5"/>

                        <Border Style="{StaticResource BaseStackPanel}">
                            <TextBox Text="{Binding InputedLname, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource BaseTextBox}"/>
                        </Border>
                    </StackPanel>

                    <!-- ROLE -->
                    <StackPanel Margin="0 10">
                        <TextBlock Text="Роль"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 5"/>

                        <ComboBox Style="{StaticResource BaseComboBox}"
                      SelectedValue="{Binding InputedIdRole}"
                      SelectedValuePath="Tag">

                            <ComboBoxItem Content="Администратор" Tag="1"/>
                            <ComboBoxItem Content="Сотрудник" Tag="2"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- PASSWORD -->
                    <StackPanel Margin="0 10">
                        <TextBlock Text="Пароль"
                       Style="{StaticResource InfoTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 5"/>

                        <Border Style="{StaticResource BaseStackPanel}">
                            <TextBox Text="{Binding InputedPassword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource BaseTextBox}"/>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

        <!-- BUTTONS -->
        <Grid Grid.Row="2" Margin="0 20">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Border Style="{StaticResource ButtonStackPanel}"
                x:Name="buttonAccept"
                        Margin="10">
                    <Button Content="{StaticResource add}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding AcceptCommand}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button Content="{StaticResource back}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding GoBackCommand}"/>
                </Border>

            </StackPanel>
        </Grid>

    </Grid>
</Page>
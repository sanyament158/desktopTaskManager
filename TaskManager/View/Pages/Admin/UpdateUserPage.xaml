<Page x:Class="TaskManager.View.Pages.Admin.UpdateUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager.View.Pages.Admin"
      mc:Ignorable="d"
      Title="UpdateUserPage"
      Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Style="{StaticResource HeaderStackPanel}">
            <TextBlock Text="Редактировать сотрудника"
                       Style="{StaticResource HeaderTextBlock}"
                       HorizontalAlignment="Center"
                       Margin="0 20"/>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="520"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- FORM -->
            <Border Grid.Column="1"
                    Background="{StaticResource grey}"
                    CornerRadius="10"
                    Margin="10"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Логин:"
                               Grid.Row="0" Grid.Column="0"
                               Style="{StaticResource InfoTextBlock}"
                               HorizontalAlignment="Right"
                               Margin="10"/>

                    <Border Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource BaseStackPanel}"
                            Margin="10">
                        <TextBox Text="{Binding InputedLogin, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BaseTextBox}"/>
                    </Border>

                    <TextBlock Text="Фамилия:"
                               Grid.Row="1" Grid.Column="0"
                               Style="{StaticResource InfoTextBlock}"
                               HorizontalAlignment="Right"
                               Margin="10"/>

                    <Border Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource BaseStackPanel}"
                            Margin="10">
                        <TextBox Text="{Binding InputedLname, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BaseTextBox}"/>
                    </Border>

                    <TextBlock Text="Роль:"
                               Grid.Row="2" Grid.Column="0"
                               Style="{StaticResource InfoTextBlock}"
                               HorizontalAlignment="Right"
                               Margin="10"/>

                    <ComboBox Grid.Row="2" Grid.Column="1"
                              Style="{StaticResource BaseComboBox}"
                              Margin="10"
                              SelectedValue="{Binding InputedIdRole}"
                              SelectedValuePath="Tag">

                        <ComboBoxItem Content="Администратор" Tag="1"/>
                        <ComboBoxItem Content="Сотрудник" Tag="2"/>
                    </ComboBox>

                    <TextBlock Text="Пароль:"
                               Grid.Row="3" Grid.Column="0"
                               Style="{StaticResource InfoTextBlock}"
                               HorizontalAlignment="Right"
                               Margin="10"/>

                    <Border Grid.Row="3" Grid.Column="1"
                            Style="{StaticResource BaseStackPanel}"
                            Margin="10">
                        <TextBox Text="{Binding InputedPassword, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BaseTextBox}"/>
                    </Border>

                </Grid>
            </Border>

            <!-- SCOPES -->
            <Border Grid.Column="2"
                    Background="{StaticResource grey}"
                    CornerRadius="10"
                    Margin="10"
                    Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView ItemsSource="{Binding SelectedUser.Scopes}"
                              DisplayMemberPath="Name"
                              BorderThickness="0"
                              Background="Transparent"
                              Margin="5"
                              FontSize="16"/>

                    <Border Grid.Row="1"
                            Style="{StaticResource ButtonStackPanel}"
                            Margin="10">

                        <Button Content="Изменить"
                                Style="{StaticResource BaseButton}"
                                Command="{Binding GoToEditScopesCommand}"/>
                    </Border>

                </Grid>
            </Border>

        </Grid>

        <!-- ACTIONS -->
        <Grid Grid.Row="2" Margin="0 20">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button Content="Редактировать"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding AcceptCommand}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}"
                        Margin="10">
                    <Button Content="{StaticResource back}"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding GoBackCommand}"/>
                </Border>

            </StackPanel>
        </Grid>

    </Grid>
</Page>
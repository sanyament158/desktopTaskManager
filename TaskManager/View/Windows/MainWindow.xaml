<Window x:Class="TaskManager.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManager.View"
        mc:Ignorable="d"
        Title="mainwindow"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Values/TextBlockStyles.xaml"/>
                <ResourceDictionary Source="/Values/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Values/BorderStyles.xaml"/>
                <ResourceDictionary Source="/Values/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Values/Strings.xaml"/>
                <ResourceDictionary Source="/Values/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Frame x:Name="mainWindowFrame" NavigationUIVisibility="Hidden" Grid.Row="1"/> 
        <DockPanel Height="100" Grid.Row="0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Background="PaleVioletRed">
                <Button Command="{Binding HomeCommand}" Background="{Binding HomeColor}">
                    <Image Source="/Icons/icon_home.png"/>
                </Button>

                <Border Style="{StaticResource ButtonStackPanel}" Margin="10" Background="{Binding ScopesColor}">                
                    <Button Content="Зоны ответственности" Command="{Binding ScopesCommand}" Style="{StaticResource BaseButton}"/> 
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}" Margin="10" Background="{Binding EmployeesColor}">
                    <Button Content="Сотрудники" Command="{Binding EmployeesCommand}" Style="{StaticResource BaseButton}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}" Margin="10" Background="{Binding AddTaskColor}">
                    <Button Content="Добавить задачу" Command="{Binding AddTaskCommand}" Style="{StaticResource BaseButton}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}" Margin="10" Background="{Binding ViewResponsibilitiesColor}">
                    <Button Content="Загруженность сотрудников" Command="{Binding ViewResponsibilitiesCommand}" Style="{StaticResource BaseButton}"/>
                </Border>

                <Border Style="{StaticResource ButtonStackPanel}" Margin="10" Background="{Binding ReportsColor}">
                    <Button Content="Отчеты" Command="{Binding ReportsCommand}" Style="{StaticResource BaseButton}"/>
                </Border>

            </StackPanel>

            <Border Style="{StaticResource ButtonStackPanel}" Margin="10 10 40 10" DockPanel.Dock="Right" HorizontalAlignment="Right" Width="140">
                <Button Content="Выйти" Command="{Binding ExitCommand}" Style="{StaticResource BaseButton}" />
            </Border>

        </DockPanel>
    </Grid>
</Window>
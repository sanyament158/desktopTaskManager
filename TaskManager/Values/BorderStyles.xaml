<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Values/Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="BaseStackPanel" TargetType="Border"> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="10"/>            
    </Style>

    <Style x:Key="HeaderStackPanel" TargetType="Border" BasedOn="{StaticResource BaseStackPanel}">
        <Setter Property="Background" Value="{StaticResource lightBrown}"/>
    </Style>

    <Style x:Key="ButtonStackPanel" TargetType="Border" BasedOn="{StaticResource BaseStackPanel}">
        <Setter Property="Background" Value="{StaticResource brown}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="20 10 20 10"/>
    </Style>

    <Style x:Key="ComboBoxHeaderStackPanel" TargetType="Border" BasedOn="{StaticResource BaseStackPanel}">
        <Setter Property="CornerRadius" Value="10 10 0 0"/>
        <Setter Property="Background" Value="{StaticResource lightBrown}"/>
    </Style>
        
</ResourceDictionary>